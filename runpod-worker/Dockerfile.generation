FROM runpod/base:0.4.1-cuda12.1.0

WORKDIR /worker

ARG LIVEPORTRAIT_REF=main

ENV WORKER_PIPELINE_MODE=generation
ENV PYTHONPATH=/worker/src
ENV PORTRAIT_REENACTMENT_RENDER_COMMAND="python3 /worker/src/generation_render_reenactment.py"
ENV PORTRAIT_REENACTMENT_PIPELINE_COMMAND="python3 /worker/src/portrait_reenactment_liveportrait.py"
ENV PORTRAIT_REENACTMENT_BACKEND="liveportrait_cli"
ENV FULL_BODY_REENACTMENT_RENDER_COMMAND="python3 /worker/src/generation_render_full_body_reenactment.py"
ENV FULL_BODY_REENACTMENT_BACKEND="unconfigured"
ENV LIVEPORTRAIT_REPO_DIR=/opt/liveportrait
ENV LIVEPORTRAIT_VENV_BIN=/opt/liveportrait-venv/bin
ENV LIVEPORTRAIT_HF_REPO=KlingTeam/LivePortrait
ENV LIVEPORTRAIT_AUTO_CROP=true
ENV LIVEPORTRAIT_AUDIO_PRIORITY=driving
ENV LIVEPORTRAIT_DRIVING_OPTION=expression-friendly
ENV LIVEPORTRAIT_ANIMATION_REGION=all
ENV GENERATION_RENDER_COMMAND="python3 /worker/src/generation_render_cogvideox.py"
ENV GENERATION_REFINE_COMMAND="python3 /worker/src/generation_refine_basic.py"
ENV GENERATION_MODEL_ID="THUDM/CogVideoX-5b-I2V"
ENV GENERATION_OFFLOAD_MODE=model
ENV GENERATION_MODEL_DTYPE=auto

RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg git python3-venv libgl1 libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt /worker/requirements.txt
COPY requirements.generation.txt /worker/requirements.generation.txt
RUN set -eux; \
    ln -sf "$(command -v python3)" /usr/local/bin/python; \
    python3 -m ensurepip --upgrade || true; \
    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel; \
    python3 -m pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cu121 torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1; \
    python3 -m pip install --no-cache-dir -r /worker/requirements.txt; \
    python3 -m pip install --no-cache-dir -r /worker/requirements.generation.txt; \
    python3 -c "import requests, runpod, torch, diffusers, transformers, accelerate, PIL; print('deps-ok')"; \
    git clone --depth 1 --branch "${LIVEPORTRAIT_REF}" https://github.com/KlingAIResearch/LivePortrait.git "${LIVEPORTRAIT_REPO_DIR}"; \
    python3 -m venv /opt/liveportrait-venv; \
    "${LIVEPORTRAIT_VENV_BIN}/python" -m pip install --no-cache-dir --upgrade pip setuptools wheel; \
    "${LIVEPORTRAIT_VENV_BIN}/python" -m pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cu121 torch==2.3.0 torchvision==0.18.0 torchaudio==2.3.0; \
    "${LIVEPORTRAIT_VENV_BIN}/python" -m pip install --no-cache-dir -r "${LIVEPORTRAIT_REPO_DIR}/requirements.txt"; \
    "${LIVEPORTRAIT_VENV_BIN}/python" -m pip install --no-cache-dir "huggingface_hub[cli]"; \
    "${LIVEPORTRAIT_VENV_BIN}/python" -c "import cv2, torch; print('liveportrait-deps-ok', torch.cuda.is_available())"; \
    test -f "${LIVEPORTRAIT_REPO_DIR}/inference.py"; \
    test -x "${LIVEPORTRAIT_VENV_BIN}/python"

COPY src /worker/src
COPY scripts /worker/scripts
RUN set -eux; \
    printf '#!/usr/bin/env bash\nexec python3 /worker/src/liveportrait_cli.py "$@"\n' > /usr/local/bin/liveportrait; \
    chmod +x /usr/local/bin/liveportrait; \
    chmod +x /worker/scripts/example_generation_render.py /worker/scripts/example_generation_refine.py; \
    chmod +x /worker/src/generation_render_cogvideox.py /worker/src/generation_render_reenactment.py /worker/src/generation_render_full_body_reenactment.py /worker/src/portrait_reenactment_liveportrait.py /worker/src/generation_refine_basic.py /worker/src/liveportrait_cli.py; \
    liveportrait --help >/dev/null
WORKDIR /worker/src

# Default generation backend is self-hosted CogVideoX image-to-video.
# Override GENERATION_RENDER_COMMAND / GENERATION_REFINE_COMMAND if you want
# to swap to another in-repo backend without changing the worker contract.

CMD ["python3", "-u", "handler.py"]
