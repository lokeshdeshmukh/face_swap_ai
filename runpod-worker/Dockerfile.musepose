FROM runpod/base:0.4.1-cuda12.1.0

WORKDIR /worker

ARG MUSEPOSE_REF=main


ENV WORKER_PIPELINE_MODE=generation
ENV PYTHONPATH=/worker/src
ENV PORTRAIT_REENACTMENT_RENDER_COMMAND="python3 /worker/src/generation_render_reenactment.py"
ENV PORTRAIT_REENACTMENT_PIPELINE_COMMAND=""
ENV PORTRAIT_REENACTMENT_BACKEND="unconfigured"
ENV FULL_BODY_REENACTMENT_RENDER_COMMAND="python3 /worker/src/generation_render_full_body_reenactment.py"
ENV FULL_BODY_REENACTMENT_PIPELINE_COMMAND="python3 /worker/src/full_body_reenactment_quality_pipeline.py"
ENV FULL_BODY_REENACTMENT_BACKEND="quality_pipeline"
ENV FULL_BODY_BASE_RENDER_STRATEGY="stronger"
ENV FULL_BODY_FACE_REFINER_COMMAND="python3 /worker/src/full_body_face_refiner_gfpgan.py"
ENV FULL_BODY_TEMPORAL_CLEANUP_COMMAND="python3 /worker/src/full_body_temporal_cleanup_ffmpeg.py"
ENV FULL_BODY_STRONGER_RENDER_WRAPPER="python3 /worker/src/full_body_reenactment_stronger_base.py"
ENV FULL_BODY_STRONGER_RENDER_COMMAND="python3 /worker/src/full_body_reenactment_musepose.py"
ENV FULL_BODY_STRONGER_RENDER_BACKEND="musepose"
ENV MUSEPOSE_REPO_DIR=/opt/musepose
ENV MUSEPOSE_VENV_BIN=/opt/musepose-venv/bin
ENV MUSEPOSE_CONFIG_PATH=/opt/musepose/configs/test_stage_2.yaml
ENV MUSEPOSE_OUTPUT_FPS=12
ENV REQUIRE_FULL_BODY_REENACTMENT_BACKEND=true
ENV GENERATION_RENDER_COMMAND="python3 /worker/src/generation_render_cogvideox.py"
ENV GENERATION_REFINE_COMMAND="python3 /worker/src/generation_refine_basic.py"
ENV GENERATION_MODEL_ID="THUDM/CogVideoX-5b-I2V"
ENV GENERATION_OFFLOAD_MODE=model
ENV GENERATION_MODEL_DTYPE=auto

RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg git python3-venv python3-av libgl1 libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt /worker/requirements.txt
COPY requirements.generation.txt /worker/requirements.generation.txt
RUN set -eux; \
    ln -sf "$(command -v python3)" /usr/local/bin/python; \
    python3 -m ensurepip --upgrade || true; \
    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel; \
    python3 -m pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cu121 torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1; \
    python3 -m pip install --no-cache-dir -r /worker/requirements.txt; \
    python3 -m pip install --no-cache-dir -r /worker/requirements.generation.txt; \
    python3 -m pip install --no-cache-dir gfpgan==1.3.8; \
    python3 -c "import requests, runpod, torch, diffusers, transformers, accelerate, PIL; print('deps-ok')"

RUN git clone --depth 1 --branch "${MUSEPOSE_REF}" https://github.com/TMElyralab/MusePose.git "${MUSEPOSE_REPO_DIR}"

RUN python3 -m venv --system-site-packages /opt/musepose-venv && \
    "${MUSEPOSE_VENV_BIN}/python" -m pip install --no-cache-dir --upgrade pip wheel "setuptools==80.9.0"

RUN if [ -f "${MUSEPOSE_REPO_DIR}/requirements.txt" ]; then \
      "${MUSEPOSE_VENV_BIN}/python" -m pip install --no-cache-dir --no-build-isolation \
        "clip @ https://github.com/openai/CLIP/archive/d50d76daa670286dd6cacf3bcd80b5e4823fc8e1.zip#sha256=b5842c25da441d6c581b53a5c60e0c2127ebafe0f746f8e15561a006c6c3be6a"; \
      "${MUSEPOSE_VENV_BIN}/python" -m pip install --no-cache-dir "torchsde==0.2.6"; \
      grep -v '^clip @ ' "${MUSEPOSE_REPO_DIR}/requirements.txt" | grep -v '^torchsde==' > /tmp/musepose-requirements.txt; \
      "${MUSEPOSE_VENV_BIN}/python" -m pip install --no-cache-dir -r /tmp/musepose-requirements.txt; \
    fi

RUN "${MUSEPOSE_VENV_BIN}/python" -m pip install --no-cache-dir openmim && \
    "${MUSEPOSE_VENV_BIN}/python" -m mim install "mmengine>=0.10.0,<1" "mmcv>=2.0.1,<3" "mmdet>=3.1.0,<4" "mmpose>=1.1.0,<2" && \
    "${MUSEPOSE_VENV_BIN}/python" -m pip install --no-cache-dir "huggingface_hub[cli]" omegaconf einops pyyaml imageio decord

RUN cd "${MUSEPOSE_REPO_DIR}" && \
    test -f "${MUSEPOSE_REPO_DIR}/pose_align.py" && \
    test -f "${MUSEPOSE_REPO_DIR}/test_stage_2.py" && \
    test -f "${MUSEPOSE_CONFIG_PATH}" && \
    "${MUSEPOSE_VENV_BIN}/python" -c "import cv2, torch, yaml; print('musepose-deps-ok', torch.cuda.is_available())"

COPY src /worker/src
COPY scripts /worker/scripts
RUN set -eux; \
    chmod +x /worker/scripts/example_generation_render.py /worker/scripts/example_generation_refine.py; \
    chmod +x /worker/src/generation_render_cogvideox.py /worker/src/generation_render_reenactment.py /worker/src/generation_render_full_body_reenactment.py /worker/src/portrait_reenactment_liveportrait.py /worker/src/full_body_reenactment_mimicmotion.py /worker/src/full_body_reenactment_quality_pipeline.py /worker/src/full_body_reenactment_stronger_base.py /worker/src/full_body_reenactment_hunyuancustom.py /worker/src/full_body_reenactment_musepose.py /worker/src/full_body_face_refiner_gfpgan.py /worker/src/full_body_temporal_cleanup_ffmpeg.py /worker/src/generation_refine_basic.py /worker/src/liveportrait_cli.py /worker/src/mimicmotion_cli.py; \
    python3 -c "import sitecustomize; print('worker-src-ok')"

WORKDIR /worker/src
CMD ["python3", "-u", "handler.py"]
